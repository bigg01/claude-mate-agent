{
  "__inputs": [
    {"name": "DS_PROMETHEUS", "label": "Prometheus", "type": "datasource", "pluginId": "prometheus", "pluginName": "Prometheus"}
  ],
  "__requires": [
    {"type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0"},
    {"type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0"},
    {"type": "panel", "id": "stat", "name": "Stat", "version": ""},
    {"type": "panel", "id": "timeseries", "name": "Time series", "version": ""},
    {"type": "panel", "id": "piechart", "name": "Pie chart", "version": ""},
    {"type": "panel", "id": "bargauge", "name": "Bar gauge", "version": ""},
    {"type": "panel", "id": "table", "name": "Table", "version": ""}
  ],
  "annotations": {"list": []},
  "description": "Anthropic API spend per persona, per namespace, per task. Burn-rate, projection, and outliers. Sourced from claude_mate_agent_task_cost_usd_total emitted by the agent on every on-demand task.",
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["claude-mate", "anthropic", "cost", "finops"],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {"text": "Prometheus", "value": "${DS_PROMETHEUS}"},
        "hide": 0
      },
      {
        "name": "namespace",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "${datasource}"},
        "query": "label_values(claude_mate_agent_task_cost_usd_total, namespace)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": {"text": "All", "value": "$__all"}
      },
      {
        "name": "role",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "${datasource}"},
        "query": "label_values(claude_mate_agent_task_cost_usd_total{namespace=~\"$namespace\"}, role)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": {"text": "All", "value": "$__all"}
      },
      {
        "name": "monthly_budget_usd",
        "type": "textbox",
        "label": "Monthly budget (USD)",
        "current": {"text": "1000", "value": "1000"},
        "hide": 0
      }
    ]
  },
  "time": {"from": "now-7d", "to": "now"},
  "timezone": "browser",
  "title": "Anthropic Cost — Spend per Persona",
  "uid": "anthropic-cost",
  "version": 1,
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Cost — last 1h (USD)",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 0},
      "targets": [{"expr": "sum(increase(claude_mate_agent_task_cost_usd_total{namespace=~\"$namespace\",role=~\"$role\"}[1h]))", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "currencyUSD", "decimals": 4, "color": {"mode": "fixed", "fixedColor": "blue"}}}
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Cost — last 24h",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 4, "w": 4, "x": 4, "y": 0},
      "targets": [{"expr": "sum(increase(claude_mate_agent_task_cost_usd_total{namespace=~\"$namespace\",role=~\"$role\"}[24h]))", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "currencyUSD", "decimals": 4, "color": {"mode": "fixed", "fixedColor": "blue"}}}
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Cost — last 7d",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 4, "w": 4, "x": 8, "y": 0},
      "targets": [{"expr": "sum(increase(claude_mate_agent_task_cost_usd_total{namespace=~\"$namespace\",role=~\"$role\"}[7d]))", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "currencyUSD", "decimals": 2, "color": {"mode": "fixed", "fixedColor": "blue"}}}
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Burn rate (USD/h, last 1h avg)",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 4, "w": 4, "x": 12, "y": 0},
      "targets": [{"expr": "sum(rate(claude_mate_agent_task_cost_usd_total{namespace=~\"$namespace\",role=~\"$role\"}[1h])) * 3600", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "currencyUSD", "decimals": 4, "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 1}, {"color": "red", "value": 10}]}}}
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Projected monthly (24h × 30 rate)",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 4, "w": 4, "x": 16, "y": 0},
      "targets": [{"expr": "sum(increase(claude_mate_agent_task_cost_usd_total{namespace=~\"$namespace\",role=~\"$role\"}[24h])) * 30", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "currencyUSD", "decimals": 2, "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": "${monthly_budget_usd}"}, {"color": "red", "value": 5000}]}}}
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Budget used (%)",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 4, "w": 4, "x": 20, "y": 0},
      "targets": [{"expr": "(sum(increase(claude_mate_agent_task_cost_usd_total{namespace=~\"$namespace\",role=~\"$role\"}[30d])) / ${monthly_budget_usd}) * 100", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "percent", "decimals": 1, "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 60}, {"color": "orange", "value": 80}, {"color": "red", "value": 100}]}, "max": 150}}
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Cost burn rate by persona (USD/h)",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 8, "w": 16, "x": 0, "y": 4},
      "targets": [
        {"expr": "sum by (role) (rate(claude_mate_agent_task_cost_usd_total{namespace=~\"$namespace\",role=~\"$role\"}[5m])) * 3600", "refId": "A", "legendFormat": "{{role}}"}
      ],
      "fieldConfig": {"defaults": {"unit": "currencyUSD", "decimals": 4}}
    },
    {
      "id": 11,
      "type": "piechart",
      "title": "Cost share by persona (7d)",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 4},
      "targets": [
        {"expr": "sum by (role) (increase(claude_mate_agent_task_cost_usd_total{namespace=~\"$namespace\",role=~\"$role\"}[7d]))", "refId": "A", "legendFormat": "{{role}}"}
      ],
      "options": {"legend": {"displayMode": "list", "placement": "right", "values": ["value", "percent"]}, "pieType": "donut", "displayLabels": ["percent"]},
      "fieldConfig": {"defaults": {"unit": "currencyUSD", "decimals": 4}}
    },
    {
      "id": 12,
      "type": "bargauge",
      "title": "Cumulative cost by persona (7d)",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
      "targets": [
        {"expr": "sum by (role) (increase(claude_mate_agent_task_cost_usd_total{namespace=~\"$namespace\",role=~\"$role\"}[7d]))", "refId": "A", "legendFormat": "{{role}}"}
      ],
      "options": {"orientation": "horizontal", "displayMode": "gradient", "showUnfilled": true},
      "fieldConfig": {"defaults": {"unit": "currencyUSD", "decimals": 4, "color": {"mode": "continuous-BlPu"}}}
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "Cost-per-task — average over 1h window",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
      "targets": [
        {"expr": "sum by (role) (increase(claude_mate_agent_task_cost_usd_total{namespace=~\"$namespace\",role=~\"$role\"}[1h])) / clamp_min(sum by (role) (increase(claude_mate_agent_task_executions_total{namespace=~\"$namespace\",role=~\"$role\",result=\"ok\"}[1h])), 1)", "refId": "A", "legendFormat": "{{role}}"}
      ],
      "fieldConfig": {"defaults": {"unit": "currencyUSD", "decimals": 4}},
      "description": "Useful for spotting expensive prompts: rising cost-per-task at the same task volume means longer / more expensive completions."
    },
    {
      "id": 14,
      "type": "timeseries",
      "title": "Task execution rate by result",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 8, "w": 16, "x": 0, "y": 20},
      "targets": [
        {"expr": "sum by (result) (rate(claude_mate_agent_task_executions_total{namespace=~\"$namespace\",role=~\"$role\"}[5m]))", "refId": "A", "legendFormat": "{{result}}"}
      ],
      "fieldConfig": {"defaults": {"unit": "ops"}}
    },
    {
      "id": 15,
      "type": "table",
      "title": "Cost leaderboard by namespace × role (last 7d)",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 20},
      "targets": [
        {"expr": "sort_desc(sum by (namespace, role) (increase(claude_mate_agent_task_cost_usd_total{namespace=~\"$namespace\",role=~\"$role\"}[7d])))", "refId": "A", "format": "table", "instant": true}
      ],
      "fieldConfig": {"defaults": {"unit": "currencyUSD", "decimals": 4}},
      "transformations": [
        {"id": "organize", "options": {"excludeByName": {"Time": true, "__name__": true, "job": true, "instance": true}, "renameByName": {"Value": "Cost (USD)"}}}
      ]
    }
  ]
}
