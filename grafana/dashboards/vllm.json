{
  "__inputs": [
    {"name": "DS_PROMETHEUS", "label": "Prometheus", "type": "datasource", "pluginId": "prometheus", "pluginName": "Prometheus"}
  ],
  "__requires": [
    {"type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0"},
    {"type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0"},
    {"type": "panel", "id": "stat", "name": "Stat", "version": ""},
    {"type": "panel", "id": "timeseries", "name": "Time series", "version": ""},
    {"type": "panel", "id": "gauge", "name": "Gauge", "version": ""}
  ],
  "annotations": {"list": []},
  "description": "vLLM serving — throughput, latency, KV cache, token I/O. Requires a Prometheus scrape job pointed at vLLM's OpenAI-compatible server /metrics endpoint.",
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["vllm", "llm", "inference", "gpu", "claude-mate"],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {"text": "Prometheus", "value": "${DS_PROMETHEUS}"},
        "hide": 0
      },
      {
        "name": "model",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "${datasource}"},
        "query": "label_values(vllm:num_requests_running, model_name)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": {"text": "All", "value": "$__all"}
      },
      {
        "name": "instance",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "${datasource}"},
        "query": "label_values(vllm:num_requests_running, instance)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": {"text": "All", "value": "$__all"}
      }
    ]
  },
  "time": {"from": "now-1h", "to": "now"},
  "timezone": "browser",
  "title": "vLLM — Serving Performance",
  "uid": "vllm-serving",
  "version": 1,
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Requests running",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 0},
      "targets": [{"expr": "sum(vllm:num_requests_running{model_name=~\"$model\",instance=~\"$instance\"})", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "short", "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 50}, {"color": "red", "value": 100}]}}}
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Requests waiting",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 4, "w": 4, "x": 4, "y": 0},
      "targets": [{"expr": "sum(vllm:num_requests_waiting{model_name=~\"$model\",instance=~\"$instance\"})", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "short", "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 10}, {"color": "red", "value": 50}]}}}
    },
    {
      "id": 3,
      "type": "gauge",
      "title": "GPU KV-cache usage",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 4, "w": 4, "x": 8, "y": 0},
      "targets": [{"expr": "avg(vllm:gpu_cache_usage_perc{model_name=~\"$model\",instance=~\"$instance\"})", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "percentunit", "min": 0, "max": 1, "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 0.7}, {"color": "red", "value": 0.9}]}}}
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Successful requests (5m)",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 4, "w": 4, "x": 12, "y": 0},
      "targets": [{"expr": "sum(increase(vllm:request_success_total{model_name=~\"$model\",instance=~\"$instance\"}[5m]))", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "short", "color": {"mode": "fixed", "fixedColor": "green"}}}
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Failed requests (5m)",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 4, "w": 4, "x": 16, "y": 0},
      "targets": [{"expr": "sum(increase(vllm:request_failure_total{model_name=~\"$model\",instance=~\"$instance\"}[5m]))", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "short", "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 1}, {"color": "red", "value": 10}]}}}
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Preemptions (5m)",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 4, "w": 4, "x": 20, "y": 0},
      "targets": [{"expr": "sum(increase(vllm:num_preemptions_total{model_name=~\"$model\",instance=~\"$instance\"}[5m]))", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "short", "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 1}, {"color": "red", "value": 10}]}}}
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "End-to-end request latency (p50 / p95 / p99)",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "targets": [
        {"expr": "histogram_quantile(0.50, sum by (le) (rate(vllm:e2e_request_latency_seconds_bucket{model_name=~\"$model\",instance=~\"$instance\"}[5m])))", "refId": "A", "legendFormat": "p50"},
        {"expr": "histogram_quantile(0.95, sum by (le) (rate(vllm:e2e_request_latency_seconds_bucket{model_name=~\"$model\",instance=~\"$instance\"}[5m])))", "refId": "B", "legendFormat": "p95"},
        {"expr": "histogram_quantile(0.99, sum by (le) (rate(vllm:e2e_request_latency_seconds_bucket{model_name=~\"$model\",instance=~\"$instance\"}[5m])))", "refId": "C", "legendFormat": "p99"}
      ],
      "fieldConfig": {"defaults": {"unit": "s"}}
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Time to first token (TTFT) p50 / p95",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "targets": [
        {"expr": "histogram_quantile(0.50, sum by (le) (rate(vllm:time_to_first_token_seconds_bucket{model_name=~\"$model\",instance=~\"$instance\"}[5m])))", "refId": "A", "legendFormat": "p50"},
        {"expr": "histogram_quantile(0.95, sum by (le) (rate(vllm:time_to_first_token_seconds_bucket{model_name=~\"$model\",instance=~\"$instance\"}[5m])))", "refId": "B", "legendFormat": "p95"}
      ],
      "fieldConfig": {"defaults": {"unit": "s"}}
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Time per output token (TPOT) p50 / p95",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
      "targets": [
        {"expr": "histogram_quantile(0.50, sum by (le) (rate(vllm:time_per_output_token_seconds_bucket{model_name=~\"$model\",instance=~\"$instance\"}[5m])))", "refId": "A", "legendFormat": "p50"},
        {"expr": "histogram_quantile(0.95, sum by (le) (rate(vllm:time_per_output_token_seconds_bucket{model_name=~\"$model\",instance=~\"$instance\"}[5m])))", "refId": "B", "legendFormat": "p95"}
      ],
      "fieldConfig": {"defaults": {"unit": "s"}}
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "Token throughput (prompt + generation tokens/sec)",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
      "targets": [
        {"expr": "sum by (model_name) (rate(vllm:prompt_tokens_total{model_name=~\"$model\",instance=~\"$instance\"}[5m]))", "refId": "A", "legendFormat": "{{model_name}} — prompt"},
        {"expr": "sum by (model_name) (rate(vllm:generation_tokens_total{model_name=~\"$model\",instance=~\"$instance\"}[5m]))", "refId": "B", "legendFormat": "{{model_name}} — generation"}
      ],
      "fieldConfig": {"defaults": {"unit": "short"}}
    },
    {
      "id": 14,
      "type": "timeseries",
      "title": "Queue depth — running vs. waiting",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 20},
      "targets": [
        {"expr": "sum by (model_name) (vllm:num_requests_running{model_name=~\"$model\",instance=~\"$instance\"})", "refId": "A", "legendFormat": "{{model_name}} — running"},
        {"expr": "sum by (model_name) (vllm:num_requests_waiting{model_name=~\"$model\",instance=~\"$instance\"})", "refId": "B", "legendFormat": "{{model_name}} — waiting"}
      ],
      "fieldConfig": {"defaults": {"unit": "short"}}
    }
  ]
}
